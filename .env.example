# Knowledge Base Search Engine Configuration

# Application
DEBUG=false

# Database
# For SQLite (default):
DATABASE_URL=sqlite:///./kb_search.db
# For PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/kb_search

# Vector Database
# Provider: memory (in-memory), qdrant (Qdrant server)
VECTOR_DB_PROVIDER=memory
# Qdrant configuration (if provider=qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=documents

# LLM Configuration
LLM_PROVIDER=openai
LLM_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o-mini

# Embedding Configuration
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Processing Parameters
DOCUMENT_CHUNK_SIZE=2000
DOCUMENT_CHUNK_OVERLAP=300

# Reranking (cross-encoder)
RERANK_ENABLED=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_CANDIDATE_COUNT=20
